# ══════════════════════════════════════════════════════════════
#  AI Locker — Environment Variables
#  Copy this file to .env and fill in your values
#  cp .env.example .env
# ══════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# URL of the frontend (used for CORS)
FRONTEND_URL=http://localhost:3000

# ── Auth (optional) ───────────────────────────────────────────
# Set this to require a Bearer token on all API requests.
# Leave empty to disable authentication (default).
#
# Generate a secure key with:
#   openssl rand -hex 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# API_KEY=your-secret-key-here

# ── Database ──────────────────────────────────────────────────
# The system auto-detects the DB in this order:
#   1. DATABASE_URL  (connection string)
#   2. DB_HOST       (individual variables)
#   3. SQLite        (default — no config needed)

# Option A: Connection string (recommended for production)
# PostgreSQL:
# DATABASE_URL=postgresql://ailocker:secret@localhost:5432/ailocker
#
# MySQL / MariaDB:
# DATABASE_URL=mysql://ailocker:secret@localhost:3306/ailocker

# Option B: Individual variables
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=ailocker
# DB_USER=ailocker
# DB_PASSWORD=secret
# DB_TYPE=postgres          # postgres | mysql | mariadb (default: postgres)

# Option C: SQLite (default — no config needed)
# Path to the SQLite database file
DB_PATH=./data/prompts.db

# ── AI Provider ───────────────────────────────────────────────
# These can also be configured from the Settings UI.
# Supported providers: openrouter | openai | anthropic | aws_bedrock

# OpenRouter (recommended — access to all models)
# AI_PROVIDER=openrouter
# AI_API_KEY=sk-or-v1-...
# AI_BASE_URL=https://openrouter.ai/api/v1
# AI_MODEL=openai/gpt-4o-mini

# OpenAI
# AI_PROVIDER=openai
# AI_API_KEY=sk-...
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o

# Anthropic
# AI_PROVIDER=anthropic
# AI_API_KEY=sk-ant-...
# AI_MODEL=claude-3-5-sonnet-20241022

# Google Gemini
# Get your API key from https://aistudio.google.com/apikey
# Available models: gemini-2.5-pro, gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash
# AI_PROVIDER=gemini
# GOOGLE_AI_API_KEY=AIzaSy...
# AI_MODEL=gemini-2.5-pro

# AWS Bedrock
# AI_PROVIDER=aws_bedrock
# AI_AWS_REGION=us-east-1
# AI_AWS_ACCESS_KEY_ID=AKIA...
# AI_AWS_SECRET_ACCESS_KEY=...
# AI_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# ── S3 / Object Storage (optional — for backups) ──────────────
# Configure from the Settings UI or set here.
# Supports AWS S3, MinIO, Cloudflare R2, and any S3-compatible storage.

# S3_BUCKET=my-ailocker-backups
# S3_REGION=us-east-1
# S3_PREFIX=ailocker-backups/

# AWS credentials (leave empty to use IAM role / instance profile)
# S3_ACCESS_KEY=AKIA...
# S3_SECRET_KEY=...

# Custom endpoint (for MinIO, R2, etc.)
# S3_ENDPOINT=https://my-minio.example.com
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# Auto-sync to S3 — value is in MINUTES
# SYNC_ENABLED=true
# SYNC_INTERVAL=60     # Common values:
#                      #   15  → every 15 minutes
#                      #   30  → every 30 minutes
#                      #   60  → every hour
#                      #   120 → every 2 hours
#                      #   360 → every 6 hours
#                      #   720 → every 12 hours
#                      #  1440 → every day  (24h)
#                      #  2880 → every 2 days
