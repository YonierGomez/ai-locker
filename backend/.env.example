PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Auth (optional) ───────────────────────────────────────────────
# Set this to require a bearer token on all API requests
# API_KEY=your-secret-key-here

# ── AI Integration (optional — can also be set in Settings UI) ────
# OPENROUTER_API_KEY=sk-or-...
# OPENAI_API_KEY=sk-...

# ── Base de datos ─────────────────────────────────────────────────
# El sistema detecta la BD en este orden:
#   1. DATABASE_URL  (string de conexión)
#   2. DB_HOST       (variables separadas)
#   3. SQLite        (por defecto, si no hay ninguna de las anteriores)

# ── Opción A: string de conexión ─────────────────────────────────
# Descomenta la línea que corresponda:
#
# PostgreSQL:
# DATABASE_URL=postgresql://promptly:secret@localhost:5432/promptly
#
# MySQL / MariaDB:
# DATABASE_URL=mysql://promptly:secret@localhost:3306/promptly

# ── Opción B: variables separadas ────────────────────────────────
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=promptly
# DB_USER=promptly
# DB_PASSWORD=secret
# DB_TYPE=postgres          # postgres | mysql | mariadb  (default: postgres)

# ── SQLite (por defecto) ──────────────────────────────────────────
DB_PATH=./data/prompts.db
